{
  "name": "zaparoo-mcp",
  "version": "0.1.0",
  "description": "MCP server for Zaparoo Core devices",
  "type": "module",
  "bin": {
    "zaparoo-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "check": "biome ci src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "build"
  ],
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "bonjour-service": "^1.3.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
